# ── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Apollo.io ───────────────────────────────────────────
APOLLO_API_KEY=your-apollo-api-key-here

# ── Hunter.io ───────────────────────────────────────────
HUNTER_API_KEY=your-hunter-api-key-here

# ── Google Maps ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── Supabase ────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# ── Gmail API ───────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# ── Redis (for Celery) ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=your-long-random-secret-key-here
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret-here

# ── App Settings ────────────────────────────────────────
MAX_LEADS_PER_RUN=200
DAILY_EMAIL_LIMIT=50
BACKEND_URL=http://localhost:8000

# ── Optional integrations ───────────────────────────────
SENDGRID_API_KEY=your-sendgrid-key-here
PHANTOMBUSTER_API_KEY=your-phantombuster-key-here
APIFY_API_KEY=your-apify-key-here
